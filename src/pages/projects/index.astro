---
import PageLayout from '@/layouts/CommonPage.astro'
import ProjectSection from '@/components/projects/ProjectSection.astro'

const headings = [
  { depth: 2, slug: 'active', text: 'active' },
  { depth: 2, slug: 'archived', text: 'archived' }
]

// TODO: replace these with your actual projects
const activeProjects = [
  {
    name: 'grog.sh',
    description: 'this website — personal blog and project portfolio, built with Astro',
    links: [
      // TODO: update with your GitHub username/repo
      { type: 'github' as const, href: 'https://github.com/mobzy/grogsh' },
      { type: 'site' as const, href: 'https://grog.sh' }
    ]
  }
]
---

<PageLayout title='projects' {headings}>
  <p>things i've built, contribute to, or find useful.</p>

  <h2 id='active'>active</h2>
  <ProjectSection projects={activeProjects} />

  <h2 id='archived'>archived</h2>
  <p class='text-muted-foreground'>nothing here yet.</p>
</PageLayout>
